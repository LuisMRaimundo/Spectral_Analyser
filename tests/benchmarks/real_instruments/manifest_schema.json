{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Real-Instrument Benchmark Manifest",
  "type": "object",
  "required": ["dataset", "records"],
  "properties": {
    "dataset": {
      "type": "object",
      "required": ["name", "source", "license", "version", "citation"],
      "properties": {
        "name": { "type": "string" },
        "source": { "type": "string" },
        "license": { "type": "string" },
        "version": { "type": "string" },
        "citation": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "instrument", "note", "source_file"],
        "properties": {
          "id": { "type": "string" },
          "instrument": { "type": "string" },
          "note": { "type": "string" },
          "dynamic": { "type": ["string", "null"] },
          "articulation": { "type": ["string", "null"] },
          "register": { "type": ["string", "null"] },
          "source_file": { "type": "string" },
          "recording_conditions": { "type": ["string", "null"] },
          "sample_rate_hz": { "type": ["number", "null"] },
          "bit_depth": { "type": ["integer", "null"] },
          "channels": { "type": ["integer", "null"] },
          "ground_truth": {
            "type": "object",
            "properties": {
              "harmonic_energy_pct_musical": { "type": ["object", "null"] },
              "inharmonic_energy_pct_musical": { "type": ["object", "null"] },
              "subbass_energy_pct_global": { "type": ["object", "null"] },
              "fatness_index": { "type": ["object", "null"] }
            },
            "additionalProperties": false
          },
          "uncertainty": {
            "type": "object",
            "properties": {
              "harmonic_energy_pct_musical": { "type": ["number", "null"] },
              "inharmonic_energy_pct_musical": { "type": ["number", "null"] },
              "subbass_energy_pct_global": { "type": ["number", "null"] },
              "fatness_index": { "type": ["number", "null"] }
            },
            "additionalProperties": false
          },
          "notes": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  }
}
